# MediMind Lab Middleware — Environment Variables
# Copy this file to .env and fill in your values.
#
# Required: MEDPLUM_CLIENT_ID, MEDPLUM_CLIENT_SECRET, MEDPLUM_PROJECT_ID
# The rest have sensible defaults.

# ── Medplum Cloud Connection ──────────────────────────────────────────
# The FHIR server where lab results are sent.
MEDPLUM_BASE_URL=https://api.medplum.com
MEDPLUM_CLIENT_ID=c7d601b8-758f-4c90-b4dd-2fe8e1d66973
MEDPLUM_CLIENT_SECRET=PASTE_YOUR_SECRET_HERE
MEDPLUM_PROJECT_ID=71c7841a-7f47-4029-8ab4-0bf62751c173

# ── REST API ──────────────────────────────────────────────────────────
# Port for the local status/health API (consumed by MediMind EMR).
API_PORT=3001

# ── Logging ───────────────────────────────────────────────────────────
# Log level: error | warn | info | debug
LOG_LEVEL=info
# Directory for log files (absolute path recommended for Windows Service).
LOG_DIR=./logs

# ── Offline Queue ─────────────────────────────────────────────────────
# SQLite database for buffering results when Medplum is unreachable.
QUEUE_DB_PATH=./data/queue.db

# ── Configuration ─────────────────────────────────────────────────────
# Path to the analyzer configuration file.
CONFIG_PATH=./config/analyzers.json
